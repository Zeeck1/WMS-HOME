# Copy this file to .env and fill in your values

# Option A (recommended for Railway): full connection string
# DB_URL=mysql://user:password@host:3306/database
# DATABASE_URL=mysql://user:password@host:3306/database
# MYSQL_URL=mysql://user:password@host:3306/database

# Option B: split DB variables (local dev or any host)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=wms_db

# Backend server port (Railway injects PORT automatically)
PORT=5000
