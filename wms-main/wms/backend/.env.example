# Copy this file to .env and fill in your values

# Option A (recommended for Railway): full connection string
# DB_URL=mysql://user:password@host:3306/database
# DATABASE_URL=mysql://user:password@host:3306/database
# MYSQL_URL=mysql://user:password@host:3306/database

# Option B: split MySQL variables
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=wms_db

# Backend server port (change if 5000 is already in use)
PORT=5000

# Google Gemini (CK Intelligence Chat) — https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSyC2JA2BFDWpqdeTSxVDhNMj8hQzWCy5QkQ
Optional model override (default: gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash